[user]
name = "David R. Morrison"
email = {{ .email | quote }}

[colors]
rest = "blue"

[ui]
log-word-wrap = true

[aliases]
tug = ["bookmark", "move", "--from", "heads(::@- & bookmarks())", "--to", "@-"]

[template-aliases]
'format_short_change_id(id)' = 'id.shortest()'
'format_short_signature(signature)' = 'signature.email().local()'
'format_timestamp(timestamp)' = 'timestamp.ago()'

[revset-aliases]
"trunk()" = "main@origin"
